NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-RB317QW06W
NEXT_PUBLIC_META_PIXEL_ID=1021361370120670
NEXT_PUBLIC_CLARITY_ID=wqmpoe0ls7
NEXT_PUBLIC_API_URL=http://localhost:4000/graphql

# Bootstrap temporal para desarrollo: usuarios de la app que pueden abrir /admin.
# En producción el backend también debe validar role=admin en todas las queries/mutations admin.
NEXT_PUBLIC_ADMIN_EMAILS=admin@moneyflow.co

NEXTAUTH_URL=http://localhost:3000

NEXTAUTH_SECRET=replace-with-a-long-random-secret
NEXT_PUBLIC_GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id.apps.googleusercontent.com

MIA_API_URL=http://localhost:4000/graphql

# GoHighLevel / LeadConnector server-side integration for Money Strategist assigned leads.
# Never expose this token with NEXT_PUBLIC_. Use a Private Integration Token with contact read scopes.
GHL_PRIVATE_INTEGRATION_TOKEN=pit_xxx
GHL_API_VERSION=2021-07-28
GHL_LOCATION_ID=your-location-id
GHL_DEFAULT_LEAD_SOURCE=Simulador de inversión
# Optional override. By default the app resolves the GHL user id by matching the logged-in coach email against /users/?locationId=GHL_LOCATION_ID.
# Use this only if the email in MIA is different from GHL or you need a manual override.
# Example string mapping: {"coach@financieramente.com":"ghl-user-id"}
# Example object mapping: {"coach@financieramente.com":{"assignedTo":"ghl-user-id","locationId":"location-id"}}
GHL_COACH_USER_MAP_JSON={}

# Comma-separated GHL opportunity.source values that are allowed in coach/MS panel.
GHL_ALLOWED_SIMULATOR_SOURCES=rentabilidad
